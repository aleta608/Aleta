Step 2: Students enrolled in 'DBMS' and 'TOC'

db.Student.find({

Enrolled_Courses: { $all: ["DBMS", "TOC"] }

}, { Name: 1, Enrolled_Courses: 1, _id: 0 }).pretty();

Step 3: Roll numbers & class of students with marks > 50 OR class = 'TE'

db.Student.find(

{ $or: [ { Marks: { $gt: 50 } }, { Class: "TE" } ] },

{ Roll_No: 1, Class: 1, Marks: 1, _id: 0 }

).pretty();

