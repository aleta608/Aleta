Step 3: Unnamed PL/SQL Block with Exception Handling

DECLARE

    v_emp_id       NUMBER := &emp_id;       -- Accept emp_id from user

    v_doj          DATE;

    v_salary       NUMBER;

    v_experience   NUMBER;

    v_new_salary   NUMBER;

    -- User-defined exception

    e_emp_not_found EXCEPTION;

    PRAGMA EXCEPTION_INIT(e_emp_not_found, -20010);

BEGIN

    -- Fetch employee data

    BEGIN

        SELECT salary, DoJ

        INTO v_salary, v_doj

        FROM Employee

        WHERE emp_id = v_emp_id;

    EXCEPTION

        WHEN NO_DATA_FOUND THEN

            RAISE_APPLICATION_ERROR(-20010, 'Employee ID ' || v_emp_id || ' not found.');

    END;

    -- Calculate years of experience from DoJ

    v_experience := TRUNC(MONTHS_BETWEEN(SYSDATE, v_doj) / 12);

    DBMS_OUTPUT.PUT_LINE('Employee ID  : ' || v_emp_id);

    DBMS_OUTPUT.PUT_LINE('Experience   : ' || v_experience || ' years');

    DBMS_OUTPUT.PUT_LINE('Current Salary: ' || v_salary);

    -- Apply increment

    IF v_experience > 10 THEN

        v_new_salary := v_salary * 1.20;    -- 20% increment

        DBMS_OUTPUT.PUT_LINE('Increment: 20% (experience > 10 years)');

    ELSIF v_experience > 5 THEN

        v_new_salary := v_salary * 1.10;    -- 10% increment

        DBMS_OUTPUT.PUT_LINE('Increment: 10% (experience > 5 years)');

    ELSE

        v_new_salary := v_salary * 1.05;    -- 5% increment

        DBMS_OUTPUT.PUT_LINE('Increment: 5% (less than 5 years)');

    END IF;

    DBMS_OUTPUT.PUT_LINE('New Salary   : ' || v_new_salary);

    -- Store in Salary_Increment table

    INSERT INTO Salary_Increment (emp_id, new_salary)

    VALUES (v_emp_id, v_new_salary);

    COMMIT;

    DBMS_OUTPUT.PUT_LINE('Salary increment stored successfully.');

EXCEPTION

    WHEN e_emp_not_found THEN

        DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLERRM);

    WHEN OTHERS THEN

        DBMS_OUTPUT.PUT_LINE('Unexpected Error: ' || SQLERRM);

        ROLLBACK;

END;

