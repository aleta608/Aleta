📝 Language: PL/SQL (Oracle).

Step 1: Create Tables

CREATE TABLE Account (

    Account_No NUMBER PRIMARY KEY,

    Cust_Name VARCHAR2(100),

    Balance NUMBER(12,2),

    NoOfYears NUMBER

);

CREATE TABLE Earned_Interest (

    Account_No NUMBER,

    Interest_Amt NUMBER(12,2)

);

