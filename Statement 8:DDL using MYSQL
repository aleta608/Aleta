CREATE VIEW Customer_Info AS
SELECT c.CustID, c.Name, c.Cust_Address, c.Age,
       a.Account_no, a.date_open, a.Balance
FROM Customer c
JOIN Account a ON c.CustID = a.CustID
WHERE c.Age < 45;

SELECT * FROM Customer_Info;


UPDATE Account SET date_open = '2017-04-16'
WHERE Account_no IN (
    SELECT Account_no FROM Customer_Info
);


