CREATE OR REPLACE PROCEDURE calc_commission
AS
    v_experience NUMBER;
    v_commission NUMBER;
BEGIN
    FOR rec IN (SELECT emp_id, salary, DoJ FROM Employee) LOOP
        v_experience := MONTHS_BETWEEN(SYSDATE, rec.DoJ) / 12;

        IF rec.salary > 10000 THEN
            v_commission := rec.salary * 0.004;
        ELSIF rec.salary < 10000 AND v_experience > 10 THEN
            v_commission := rec.salary * 0.0035;
        ELSIF rec.salary < 3000 THEN
            v_commission := rec.salary * 0.0025;
        ELSE
            v_commission := rec.salary * 0.0015;
        END IF;

        UPDATE Employee
        SET commission = v_commission
        WHERE emp_id = rec.emp_id;

        DBMS_OUTPUT.PUT_LINE('Emp: ' || rec.emp_id || ' | Commission: ' || v_commission);
    END LOOP;
    COMMIT;
END;
/


SET SERVEROUTPUT ON;
EXEC calc_commission;
SELECT emp_id, emp_name, salary, commission FROM Employee;


