UPDATE Customer SET Cust_Address = 'Pune' WHERE CustID = 3;

Step 5: View – Loan_account

CREATE VIEW Loan_account AS

SELECT c.CustID, c.Name, c.Cust_Address, c.Age, a.Account_no, a.open_date, a.Balance

FROM Customer c

JOIN Account a ON c.CustID = a.CustID

WHERE a.Account_type = 'Loan Account'

AND a.open_date = '2018-02-16';

SELECT * FROM Loan_account;

