Step 3: View – Saving_account

CREATE VIEW Saving_account AS

SELECT c.CustID, c.Name, c.Cust_Address, c.Age, a.Account_no, a.open_date, a.Balance

FROM Customer c

JOIN Account a ON c.CustID = a.CustID

WHERE a.Account_type = 'Saving Account'

AND a.open_date = '2018-08-16';

SELECT * FROM Saving_account;

