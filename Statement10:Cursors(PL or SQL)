INSERT INTO Employee VALUES (3, 'Arjun Das', 90000);
INSERT INTO Employee VALUES (4, 'Meena Joshi', 30000);
INSERT INTO Employee VALUES (5, 'Sam Patel', 60000);
COMMIT;


DECLARE
 CURSOR c_emp IS
   SELECT * FROM Employee WHERE Salary > 50000;
 v_rec c_emp%ROWTYPE;
BEGIN
 OPEN c_emp;
 LOOP
   FETCH c_emp INTO v_rec;
   EXIT WHEN c_emp%NOTFOUND;
   DBMS_OUTPUT.PUT_LINE('ID: ' || v_rec.Emp_id || ' | Name: ' || v_rec.Emp_Name || ' | Salary: ' || v_rec.Salary);
 END LOOP;
 CLOSE c_emp;
END;
/


DECLARE
 v_count NUMBER;
BEGIN
 SELECT COUNT(*) INTO v_count FROM Employee;
 DBMS_OUTPUT.PUT_LINE('Total tuples in Employee table: ' || v_count);
END;
/


DECLARE
 v_emp_id NUMBER := &emp_id;
 CURSOR c_emp_salary(p_id NUMBER) IS
   SELECT Emp_id, Emp_Name, Salary FROM Employee WHERE Emp_id = p_id;
 v_rec c_emp_salary%ROWTYPE;
BEGIN
 OPEN c_emp_salary(v_emp_id);
 FETCH c_emp_salary INTO v_rec;
 IF c_emp_salary%FOUND THEN
   DBMS_OUTPUT.PUT_LINE('Employee ID   : ' || v_rec.Emp_id);
   DBMS_OUTPUT.PUT_LINE('Employee Name : ' || v_rec.Emp_Name);
   DBMS_OUTPUT.PUT_LINE('Salary        : ' || v_rec.Salary);
 ELSE
   DBMS_OUTPUT.PUT_LINE('No employee found');
 END IF;
 CLOSE c_emp_salary;
END;
/
