CREATE TABLE Employee (
 emp_id NUMBER PRIMARY KEY,
 dept_id NUMBER,
 emp_name VARCHAR2(100),
 DoJ DATE,
 salary NUMBER(12,2),
 commission NUMBER(10,2),
 job_title VARCHAR2(100)
);

CREATE TABLE job_history (
 emp_id NUMBER,
 old_job_title VARCHAR2(100),
 old_dept_id NUMBER,
 start_date DATE,
 end_date DATE
);


CREATE OR REPLACE TRIGGER trg_no_salary_decrease
BEFORE UPDATE OF salary ON Employee
FOR EACH ROW
BEGIN
 IF :NEW.salary < :OLD.salary THEN
  RAISE_APPLICATION_ERROR(-20002,'Salary cannot be decreased');
 END IF;
END;
/


CREATE OR REPLACE TRIGGER trg_job_title_change
AFTER UPDATE OF job_title ON Employee
FOR EACH ROW
BEGIN
 INSERT INTO job_history VALUES(:OLD.emp_id,:OLD.job_title,:OLD.dept_id,:OLD.DoJ,SYSDATE);
END;
/
