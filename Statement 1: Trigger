📝 Language: PL/SQL (Oracle).

Step 1: Create Tables

CREATE TABLE Employee (

    emp_id NUMBER PRIMARY KEY,

    emp_name VARCHAR2(100),

    salary NUMBER(10,2),

    designation VARCHAR2(50)

);

CREATE TABLE Salary_Backup (

    emp_id NUMBER,

    old_salary NUMBER(10,2),

    new_salary NUMBER(10,2),

    salary_difference NUMBER(10,2)

);

Step 2: Insert Sample Data

INSERT INTO Employee VALUES (101,'Alice',50000,'Manager');

INSERT INTO Employee VALUES (102,'Bob',30000,'Developer');

INSERT INTO Employee VALUES (103,'Carol',90000,'CEO');

COMMIT;

Step 3: Trigger to Record Salary Changes

CREATE OR REPLACE TRIGGER trg_salary_change

AFTER UPDATE OF salary ON Employee

FOR EACH ROW

BEGIN

INSERT INTO Salary_Backup(emp_id,old_salary,new_salary,salary_difference)

VALUES(:OLD.emp_id,:OLD.salary,:NEW.salary,:NEW.salary-:OLD.salary);

END;

/

Step 4: Test Trigger

UPDATE Employee SET salary = 55000 WHERE emp_id = 101;

COMMIT;

SELECT * FROM Salary_Backup;

Step 5: Trigger to Prevent Deletion of CEO

CREATE OR REPLACE TRIGGER trg_prevent_ceo_delete

BEFORE DELETE ON Employee

FOR EACH ROW

BEGIN

IF :OLD.designation = 'CEO' THEN

RAISE_APPLICATION_ERROR(-20001,'ERROR: Cannot delete an employee with designation CEO.');

END IF;

END;

/

